<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deeplinks — App Links (autoVerify) for https://cityriders.id/*.
                 Partner QR codes encode https://cityriders.id/p/{slug},
                 driver business cards encode https://cityriders.id/r/{slug}.
                 Without this filter, scanning a QR opens Chrome instead of
                 the installed app even when the user has us installed.

                 autoVerify requires `.well-known/assetlinks.json` to be
                 served by the host with a SHA-256 fingerprint matching
                 the signing key — see public/.well-known/assetlinks.json
                 and update the SHA-256 once the release keystore is
                 generated (PLAYSTORE_CHECKLIST.md §1). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="cityriders.id" />
                <data android:scheme="https" android:host="www.cityriders.id" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions
         INTERNET            — WebView talks to the live Next.js site.
         ACCESS_*_LOCATION   — pure GPS, both fine + coarse.
         ACCESS_BACKGROUND_LOCATION — required for the location ping
                              to fire while the app is backgrounded /
                              the phone screen is locked. This is the
                              whole reason we have a native shell.
         FOREGROUND_SERVICE  — Android 9+ requirement for any service
                              that runs while the app is backgrounded.
         FOREGROUND_SERVICE_LOCATION — Android 14+ requirement to
                              declare WHICH foreground-service type
                              we're running.
         POST_NOTIFICATIONS  — Android 13+ requires runtime permission
                              before showing the persistent "City
                              Rider is online" notification.
         WAKE_LOCK           — keep CPU awake long enough to deliver
                              location fixes; the plugin handles the
                              actual partial-wake-lock acquisition.
         REQUEST_IGNORE_BATTERY_OPTIMIZATIONS — required so the driver
                              can whitelist City Rider against
                              aggressive vendor battery-savers
                              (Xiaomi MIUI, Oppo ColorOS, Vivo FunTouch
                              ~70% of Indonesia handsets). Without
                              whitelisting, the foreground location
                              service is killed after ~30-60 min, the
                              driver silently goes "offline" mid-shift
                              and stops appearing on the marketplace.
                              GOOGLE PLAY NOTE: this permission is
                              flagged as sensitive — the in-app
                              prominent-disclosure modal in
                              GoOnlineToggle.tsx already covers GPS;
                              the BatteryOptPromptModal handles this
                              one. We invoke it via a tiny in-app
                              BatteryOpt plugin (intent-only, no
                              policy-violating background work).
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- VIBRATE — required by the "bookings" notification channel for the
         booking-alert vibration pattern (see src/lib/capacitor/pushChannel.ts). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- The Android 14+ <service android:foregroundServiceType="location">
         element is injected at manifest-merge time by
         @capacitor-community/background-geolocation (see its own
         AndroidManifest.xml inside node_modules). After running
         `npx cap sync android` the merged APK manifest at
         android/app/build/intermediates/merged_manifests/.../AndroidManifest.xml
         will contain the declaration — VERIFY post-sync if changing the
         plugin version. -->
</manifest>
