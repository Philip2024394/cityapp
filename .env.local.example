# ============================================================================
# City Rider — environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values from your Supabase
# project (Settings → API). The app boots in legacy demo mode when env vars
# are absent so you can develop without a Supabase project yet.
# ============================================================================

# Supabase project (Singapore region recommended for Indonesia)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-only. NEVER expose to the browser.
# Used by /api/* routes for trip writes, trip_events, admin actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL — used in generated links (rider profile share, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Self-hosted PMTiles on Cloudflare R2 (optional — see TILE_RESILIENCE.md)
# When set, replaces tiles.openfreemap.org as the vector tile source.
NEXT_PUBLIC_PMTILES_URL=

# Cloudflare Turnstile (captcha) — protects /api/affiliate/signup and
# /api/affiliate/track-share. Get keys at https://dash.cloudflare.com/
# (Turnstile). The site key is PUBLIC, the secret is server-only.
# When TURNSTILE_SECRET_KEY is unset the verifier degrades to ok:true so
# local dev still works; the affiliate routes log a one-time warning.
# Test keys (Cloudflare-published, dev only):
#   site key  (always passes): 1x00000000000000000000AA
#   secret    (always passes): 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
