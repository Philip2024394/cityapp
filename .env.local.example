# ============================================================================
# City Rider — environment variables (complete reference)
# ============================================================================
# Copy this file to .env.local for local dev. For Vercel Preview + Production,
# set the same keys in the Vercel dashboard (Settings → Environment Variables).
#
# The app boots in legacy demo mode when most env vars are absent, but several
# routes will 4xx or silently degrade — see the section headers below for
# which features each group unlocks.
#
# Audit cross-reference: every var listed here is grep-verified as actually
# read by code in src/ or instrumentation.ts (as of 2026-05-24).
# ============================================================================


# ── REQUIRED for any Supabase backend (the most basic auth + DB layer) ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by /api/* for trip writes, trip_events, admin actions,
# cron jobs. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ── REQUIRED for canonical URLs in og:tags, sitemap, share links ───────────
# Defaults to https://cityriders.id when unset — set explicitly to a Vercel
# preview URL when testing PR branches against real data.
NEXT_PUBLIC_SITE_URL=https://cityriders.id
NEXT_PUBLIC_APP_URL=https://cityriders.id


# ── REQUIRED for Midtrans subscription billing (Rp 38,000/month per rider) ─
# Without these, the subscription Snap modal fails — drivers can sign up but
# can't activate. Test in sandbox first, then flip MIDTRANS_PRODUCTION=true.
# See SETUP_OPS.md §2 for the dashboard walkthrough.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_PRODUCTION=false


# ── REQUIRED for /api/cron/* routes (Vercel-scheduled or external pings) ───
# Generate with: openssl rand -hex 32
# Without this, cron endpoints 401 — affiliate payouts + cleanup never run.
CRON_SECRET=


# ── REQUIRED for /api/affiliate/* (after migration 0018) ───────────────────
# Generate with: openssl rand -hex 32
AFFILIATE_SESSION_SECRET=


# ── REQUIRED for /api/admin/gateway/* (admin API auth) ─────────────────────
# Bearer token expected by admin routes; pair with a comma-separated list of
# allowed origins so the admin console at streetlocal.live can call cityrider
# admin endpoints.
ADMIN_GATEWAY_SECRET=
ADMIN_GATEWAY_ALLOWED_ORIGINS=https://streetlocal.live,https://www.streetlocal.live


# ── REQUIRED for push notifications (Capacitor APK + web push) ─────────────
# Firebase Cloud Messaging service-account JSON, paste as a single line of
# escaped JSON. Generate at console.firebase.google.com → Service Accounts.
# Without it, push registration succeeds but no notifications ever fire.
FCM_SERVICE_ACCOUNT_JSON=


# ── REQUIRED for Indonesian legal compliance (privacy/terms pages) ─────────
# Without these the /legal and /privacy pages show literal {{PLACEHOLDER}}
# text — fails PDP (UU 27/2022) + would block Google Play submission for
# the Background Location justification.
NEXT_PUBLIC_LEGAL_ENTITY_NAME=PT Your Legal Entity Name
NEXT_PUBLIC_LEGAL_ENTITY_ADDRESS=Full registered address, Indonesia
NEXT_PUBLIC_LEGAL_ENTITY_CONTACT_EMAIL=legal@cityriders.id
NEXT_PUBLIC_LEGAL_ENTITY_CONTACT_WHATSAPP=+62XXXXXXXXXX
NEXT_PUBLIC_LEGAL_ENTITY_NPWP=00.000.000.0-000.000
NEXT_PUBLIC_LEGAL_ENTITY_PSE_NUMBER=KOMINFO PSE registration number


# ── RECOMMENDED for production error monitoring ────────────────────────────
# Sentry initialises silently when these are unset → errors go to Vercel
# function logs (24h retention on Hobby, 30d Pro). Create project at
# sentry.io and paste all 4 to get real-time alerting + 90d retention.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Only needed for source-map upload during build:
SENTRY_AUTH_TOKEN=


# ── OPTIONAL · road-distance routing (deferred until Phase 2) ──────────────
# Self-hosted OSRM endpoint (see SETUP_OPS.md §5 for Hetzner deploy notes).
# Founder decision 2026-06-02: NOT deployed yet. The /api/quote/route-distance
# proxy falls back to haversine × 1.3 (empirically validated within 5–10% on
# 200 Yogya/Bali routes) which is well below the noise floor for a directory
# product where the final fare is negotiated on WhatsApp anyway. Defer OSRM
# until customer volume justifies the VPS spend. When the time comes, host
# at osrm.citydrivers.id (driver app's canonical domain).
# OSRM_BASE_URL=https://osrm.citydrivers.id


# ── RECOMMENDED for Cloudflare R2 vector tiles (offline + faster) ──────────
# When set, replaces tiles.openfreemap.org as the vector tile source.
# See TILE_RESILIENCE.md for the R2 setup.
NEXT_PUBLIC_PMTILES_URL=


# ── RECOMMENDED for transactional email (receipts, password reset) ─────────
# Without these, /api/email/* routes return ok but don't actually send.
RESEND_API_KEY=
RESEND_FROM=City Rider <receipts@cityriders.id>
RESEND_REPLY_TO=support@cityriders.id


# ── RECOMMENDED for IP-hashed analytics (privacy-preserving) ───────────────
# Generate each with: openssl rand -hex 32. Without these, the IP hashing
# salt is empty string → duplicate-detection across visitors breaks down.
IP_SALT=
REVIEW_IP_SALT=


# ── RECOMMENDED for affiliate captcha (anti-spam on signup forms) ──────────
# See TURNSTILE notes near the bottom for test keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Test keys (Cloudflare-published, dev only):
#   site key  (always passes): 1x00000000000000000000AA
#   secret    (always passes): 1x0000000000000000000000000000000AA


# ── REQUIRED if calling the StreetLocal main DB (cross-app reads) ──────────
# A few routes read the parent streetlocal Supabase project for cross-app
# user lookups (vendor profiles, affiliate tracking). Set ONLY if those
# routes are in use.
STREETLOCAL_SUPABASE_URL=
STREETLOCAL_SUPABASE_SERVICE_KEY=


# ── OPTIONAL feature flags ─────────────────────────────────────────────────
# B2B Pro tier gating (contract-driver directory in /business). When 'true',
# only paid restaurants/Shopee partners see the rider directory.
NEXT_PUBLIC_B2B_TIER_ENFORCEMENT=false

# Driver WhatsApp community link surfaced in dashboard onboarding.
NEXT_PUBLIC_DRIVER_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/XXXXXXXX


# ── OPTIONAL AI agent (Anthropic — admin support / customer-help bot) ──────
# Without these, the agent endpoints respond with a "not configured" hint
# and the UI hides the agent surface.
ANTHROPIC_API_KEY=
AGENT_ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5-20250929


# ── OPTIONAL — PDP / internal notifications ────────────────────────────────
# Email recipient for PDP-compliance reminders + nightly digests.
PDP_REMINDER_TO=ops@cityriders.id


# ── BUILD-TIME OVERRIDE (Capacitor only) ───────────────────────────────────
# When building the Android APK, override the WebView's server.url to point
# at a Vercel preview deployment instead of production.
# Used by capacitor.config.ts. Not needed for Vercel deploys.
# CAPACITOR_SERVER_URL=https://cityriders-preview.vercel.app


# ── AUTO-INJECTED — don't set yourself ─────────────────────────────────────
# These are populated automatically by Vercel + Next.js — listed here only
# so anyone reading this file knows they exist and are consumed by code:
#   VERCEL_ENV               — 'production' | 'preview' | 'development'
#   VERCEL_GIT_COMMIT_SHA    — short SHA of the deployed commit
#   NEXT_PUBLIC_VERCEL_ENV   — same as VERCEL_ENV, exposed to client bundle
#   NEXT_PUBLIC_BUILD_SHA    — manually set during CI for non-Vercel deploys
#   NODE_ENV, NEXT_RUNTIME   — set by Next.js itself
