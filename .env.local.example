# ============================================================================
# City Rider — environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values from your Supabase
# project (Settings → API). The app boots in legacy demo mode when env vars
# are absent so you can develop without a Supabase project yet.
# ============================================================================

# Supabase project (Singapore region recommended for Indonesia)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-only. NEVER expose to the browser.
# Used by /api/* routes for trip writes, trip_events, admin actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL — used in generated links (rider profile share, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Self-hosted PMTiles on Cloudflare R2 (optional — see TILE_RESILIENCE.md)
# When set, replaces tiles.openfreemap.org as the vector tile source.
NEXT_PUBLIC_PMTILES_URL=
