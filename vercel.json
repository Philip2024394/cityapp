{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "crons": [
    { "path": "/api/admin/payouts/aggregate",       "schedule": "0 1 * * 1" },
    { "path": "/api/admin/subscriptions/expire",    "schedule": "0 18 * * *" },
    { "path": "/api/admin/retention/sweep",         "schedule": "0 19 * * *" },
    { "path": "/api/admin/b2b/recompute-scores",    "schedule": "0 20 * * *" },
    { "path": "/api/admin/payment-intents/expire",  "schedule": "0 21 * * *" },
    { "path": "/api/admin/reminders/payments",      "schedule": "0 1 * * *" },
    { "path": "/api/admin/pdp/overdue",             "schedule": "0 2 * * *" },
    { "path": "/api/cron/partner-suspend",          "schedule": "0 * * * *" },
    { "path": "/api/ops/route-health",              "schedule": "*/5 * * * *" }
  ]
}
