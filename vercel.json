{
  "buildCommand": "next build",
  "framework": "nextjs",
  "regions": ["sin1"],
  "crons": [
    { "path": "/api/admin/payouts/aggregate?secret=$CRON_SECRET",      "schedule": "0 1 * * 1" },
    { "path": "/api/admin/subscriptions/expire?secret=$CRON_SECRET",   "schedule": "0 18 * * *" },
    { "path": "/api/admin/retention/sweep?secret=$CRON_SECRET",        "schedule": "0 19 * * *" },
    { "path": "/api/admin/b2b/recompute-scores?secret=$CRON_SECRET",   "schedule": "0 20 * * *" },
    { "path": "/api/admin/payment-intents/expire?secret=$CRON_SECRET", "schedule": "0 21 * * *" },
    { "path": "/api/admin/reminders/payments?secret=$CRON_SECRET",     "schedule": "0 1 * * *" },
    { "path": "/api/admin/pdp/overdue?secret=$CRON_SECRET",            "schedule": "0 2 * * *" },
    { "path": "/api/cron/partner-suspend?secret=$CRON_SECRET",         "schedule": "0 3 * * 1" }
  ]
}
